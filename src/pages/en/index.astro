---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getTranslation } from '@/i18n/i18n';
import HomeJumbo from '@/components/react/HomeJumbo';
import '@/styles/jumbo.scss';
import '@/styles/home.scss';

const locale = 'en';
const t = await getTranslation(locale);
const tNumbers = await getTranslation(locale, 'pages.home.numbers');
const tTickets = await getTranslation(locale, 'pages.home.tickets');
const tPhotos = await getTranslation(locale, 'pages.home.photos');
const tMap = await getTranslation(locale, 'pages.attending.map');
const tPartners = await getTranslation(locale, 'pages.partners');

import partnersData from '../../../data/partners.json';
const pxlPartners = (partnersData as any).PXL?.filter((p: any) => !p.hidden) || [];
const platiniumPartners = (partnersData as any).Platinium?.filter((p: any) => !p.hidden) || [];

const photos = [
  { src: '/images/home/album/faucheuses.jpg', alt: '' },
  { src: '/images/home/album/equipe-amphi.jpg', alt: '' },
  { src: '/images/home/album/adrien.jpg', alt: '' },
  { src: '/images/home/album/annabelle-jef.jpg', alt: '' },
  { src: '/images/home/album/chef.jpg', alt: '' },
  { src: '/images/home/album/stand.jpg', alt: '' },
  { src: '/images/home/album/concert.jpg', alt: '' },
  { src: '/images/home/album/2000.jpg', alt: '' },
];
---

<BaseLayout locale={locale}>
  <HomeJumbo client:load locale={locale} />

  <div class="section">
    <h1>{t('pages.home.what-is')}</h1>
    <p>{t('site.description')}</p>
    <p>{t('site.theme')}</p>

    <div class="numbers-grid">
      <div class="number-item"><h2 class="no-leaf">{3500}</h2><p>{tNumbers('attendees')}</p></div>
      <div class="number-item"><h2 class="no-leaf">{2}</h2><p>{tNumbers('days')}</p></div>
      <div class="number-item"><h2 class="no-leaf">{71}</h2><p>{tNumbers('sessions')}</p></div>
      <div class="number-item"><h2 class="no-leaf">{4}</h2><p>{tNumbers('tracks')}</p></div>
      <div class="number-item"><h2 class="no-leaf">90+</h2><p>{tNumbers('speakers')}</p></div>
    </div>

    <div style="text-align: center;">
      <img src="/images/affiche.jpg" style="width: 50%; height: auto;" alt="Poster" />
    </div>

    <div class="our-values-link">
      <a href={`/${locale}/our-values`}>
        <span style="font-size: 60px;">♿</span>
        <p>{tNumbers('our-values')}</p>
      </a>
    </div>

    <div style="text-align: center;">
      <h2>Teaser 2027</h2>
      <div class="youtube-container">
        <iframe
          src="https://www.youtube-nocookie.com/embed/t_1-8ajyO6c"
          title="Teaser 2027"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          referrerpolicy="strict-origin-when-cross-origin"
          allowfullscreen
          frameborder="0"
        ></iframe>
      </div>
    </div>
  </div>

  <div class="section full-width" style="background: var(--tertiary);">
    <div style="display: flex; justify-content: center;">
      <img src="/images/plan-cite-transparent.png" alt="Plan H Arena" style="object-fit: contain; max-height: 600px; width: auto;" />
    </div>
  </div>

  <div class="section map-section-mobile">
    <h2 style="margin-top: 0;">{tMap('title')}</h2>
    <h3>H Arena, Nantes, France</h3>
    <p>{tMap('description')}</p>
    <a href="https://www.google.com/maps/dir/?api=1&destination=47.2058,-1.5243" target="_blank" class="btn btn-secondary">
      44 Bd de la Prairie au Duc, 44200 Nantes →
    </a>
  </div>
  <div class="map-section-desktop">
    <img alt="world map" src="/images/home/map.jpg" style="height: 100%; width: 100%; object-fit: cover;" />
    <div class="map-overlay">
      <h2 style="margin-top: 0;">{tMap('title')}</h2>
      <h3>H Arena, Nantes, France</h3>
      <p>{tMap('description')}</p>
      <a href="https://www.google.com/maps/dir/?api=1&destination=47.2058,-1.5243" target="_blank" class="btn btn-secondary">
        44 Bd de la Prairie au Duc, 44200 Nantes →
      </a>
    </div>
  </div>

  <div class="section full-width">
    <h2>{tTickets('name')}</h2>
    <div class="tickets-grid">
      <div class="ticket-wrapper">
        <div class="ticket active">
          <div class="ticket-header">✨ {tTickets('2days-2nd')} ✨</div>
          <div class="ticket-price">110 € <span class="ht">HT</span></div>
          <div class="ticket-info"><p>2400 places</p><p>11/09/2027 23h55</p></div>
        </div>
      </div>
      <div class="ticket-wrapper">
        <div class="ticket active">
          <div class="ticket-header">✨ {tTickets('1day')} ✨</div>
          <div class="ticket-price">70 € <span class="ht">HT</span></div>
          <div class="ticket-info"><p>700 places</p><p>11/09/2027 23h55</p></div>
        </div>
      </div>
    </div>
  </div>

  <div class="section full-width">
    <h2>{tPartners('pxl')}</h2>
    <div class="partners-grid pxl">
      {pxlPartners.map((partner: any) => (
        <a href={partner.website} target="_blank" rel="noopener noreferrer" class="partner-link">
          <div class="image-container">
            <img class="partner-logo" alt={partner.title} src={`/images/partners/${partner.image}`} />
          </div>
        </a>
      ))}
    </div>
  </div>

  <div class="section full-width">
    <h2>{tPartners('platinium-partners')}</h2>
    <div class="partners-grid platinium">
      {platiniumPartners.map((partner: any) => (
        <a href={partner.website} target="_blank" rel="noopener noreferrer" class="partner-link">
          <div class="image-container">
            <img class="partner-logo" alt={partner.title} src={`/images/partners/${partner.image}`} />
          </div>
        </a>
      ))}
    </div>
  </div>

  <div class="section full-width">
    <div class="photos-grid">
      <div class="photo-item high" style="grid-column: 1; grid-row: span 2;"><img src={photos[0].src} alt="" /></div>
      <div class="photo-item low" style="grid-column: span 2;"><img src={photos[1].src} alt="" /></div>
      <div class="photo-item low" style="grid-column: span 2;"><img src={photos[2].src} alt="" style="object-position: top;" /></div>
      <div class="photo-tile" style="grid-column: span 2;">
        <p>{tPhotos('p1')}</p>
        <p style="margin-top: 0;">{tPhotos('p2')}</p>
        <a href="https://photos.app.goo.gl/H1EqkeCNkjjYMxCCA" target="_blank" class="btn btn-primary">{tPhotos('button')}</a>
      </div>
      <div class="photo-item high" style="grid-column: span 1; grid-row: span 2;"><img src={photos[3].src} alt="" /></div>
      <div class="photo-item square" style="grid-column: span 1;"><img src={photos[4].src} alt="" /></div>
      <div class="photo-item low" style="grid-column: span 2;"><img src={photos[7].src} alt="" /></div>
      <div class="photo-item square" style="grid-column: span 1;"><img src={photos[5].src} alt="" /></div>
      <div class="photo-item square no-mobile" style="grid-column: span 1;"><img src={photos[6].src} alt="" /></div>
    </div>
  </div>
</BaseLayout>

<style>
  .numbers-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 8px; justify-items: center; margin: 20px 0; }
  @media (max-width: 900px) { .numbers-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 600px) { .numbers-grid { grid-template-columns: repeat(2, 1fr); } }
  .number-item { text-align: center; min-width: 100px; }
  .number-item h2 { margin: 10px 0; }
  .youtube-container { position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; }
  .youtube-container iframe { position: absolute; top: 0; left: 0; width: 100%; height: 100%; }
  .map-section-mobile { display: block; }
  .map-section-desktop { display: none; position: relative; height: 600px; width: 100%; }
  @media (min-width: 600px) { .map-section-mobile { display: none; } .map-section-desktop { display: block; } }
  .map-overlay { position: absolute; bottom: 20px; left: 20px; background-color: var(--primary); color: white; padding: 20px; max-width: 40vw; }
  .tickets-grid { display: flex; justify-content: center; gap: 24px; flex-wrap: wrap; margin: 20px 0; }
  .partners-grid { display: flex; align-items: center; justify-content: center; gap: 40px; flex-wrap: wrap; }
  .partners-grid.pxl .partner-link { max-width: 475px; max-height: 275px; }
  .partners-grid.platinium .partner-link { max-width: 300px; max-height: 175px; }
  .partner-link { display: block; width: 100%; max-width: 300px; }
  .image-container { position: relative; padding-top: 56.25%; overflow: hidden; transition: transform 0.3s ease, box-shadow 0.3s ease; }
  .image-container:hover { transform: scale(1.1); cursor: pointer; box-shadow: rgba(0, 0, 0, 0.15) 1.95px 1.95px 2.6px; }
  .partner-logo { position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: contain; }
  .photos-grid { display: grid; gap: 8px; grid-template-columns: repeat(5, 1fr); grid-template-rows: repeat(3, 30vh); grid-auto-flow: dense; }
  @media (max-width: 600px) { .photos-grid { grid-template-columns: repeat(3, 1fr); grid-template-rows: repeat(5, 17vh); } .no-mobile { display: none; } }
  .photo-item img { width: 100%; height: 100%; object-fit: cover; }
  .photo-item.square img { aspect-ratio: 1 / 1; }
  .photo-item.low img { aspect-ratio: 16 / 9; }
  .photo-tile { display: flex; flex-direction: column; align-items: center; justify-content: center; }
  .btn { display: inline-block; padding: 8px 16px; border-radius: 4px; text-decoration: none; font-size: 0.95rem; cursor: pointer; color: white; }
  .btn-secondary { background-color: var(--secondary); }
  .btn-secondary:hover { opacity: 0.9; }
  .btn-primary { background-color: var(--primary); border: 1px solid rgba(255, 255, 255, 0.3); }
  .btn-primary:hover { background-color: #1a2d42; }
</style>
