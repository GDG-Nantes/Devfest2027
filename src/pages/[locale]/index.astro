---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getTranslation } from '@/i18n/i18n';
import { getLocaleFromParams } from '@/i18n/i18n';
import i18nConfig from '@/i18n/i18nConfig';
import HomeJumbo from '@/components/react/HomeJumbo';
import InteractiveMap from '@/components/react/InteractiveMap';
import '@/styles/jumbo.scss';
import '@/styles/home.scss';
import { getUiSvgIcon } from '@/components/icons/flat-icons';

export function getStaticPaths() {
  return i18nConfig.locales.map((locale) => ({ params: { locale } }));
}

const locale = getLocaleFromParams(Astro.params);
const t = await getTranslation(locale);
const tNumbers = await getTranslation(locale, 'pages.home.numbers');
const tTickets = await getTranslation(locale, 'pages.home.tickets');
const tPhotos = await getTranslation(locale, 'pages.home.photos');
const tMap = await getTranslation(locale, 'pages.attending.map');

// Photo album
const photos = [
  { src: '/images/home/album/faucheuses.jpg', alt: '' },
  { src: '/images/home/album/equipe-amphi.jpg', alt: '' },
  { src: '/images/home/album/adrien.jpg', alt: '' },
  { src: '/images/home/album/annabelle-jef.jpg', alt: '' },
  { src: '/images/home/album/chef.jpg', alt: '' },
  { src: '/images/home/album/stand.jpg', alt: '' },
  { src: '/images/home/album/concert.jpg', alt: '' },
  { src: '/images/home/album/2000.jpg', alt: '' },
];
---

<BaseLayout locale={locale}>
  <!-- Jumbo -->
  <HomeJumbo client:load locale={locale} />

  <!-- What is DevFest -->
  <div class="section">
    <h1>{t('pages.home.what-is')}</h1>
    <p>{t('site.description')}</p>
    <p>{t('site.theme')}</p>

    <!-- Numbers -->
    <h2>{tNumbers('title')}</h2>
    <div class="numbers-grid">
      <div class="number-item">
        <h2 class="no-leaf">{3500}</h2>
        <p>{tNumbers('attendees')}</p>
      </div>
      <div class="number-item">
        <h2 class="no-leaf">{2}</h2>
        <p>{tNumbers('days')}</p>
      </div>
      <div class="number-item">
        <h2 class="no-leaf">{71}</h2>
        <p>{tNumbers('sessions')}</p>
      </div>
      <div class="number-item">
        <h2 class="no-leaf">{4}</h2>
        <p>{tNumbers('tracks')}</p>
      </div>
      <div class="number-item">
        <h2 class="no-leaf">90+</h2>
        <p>{tNumbers('speakers')}</p>
      </div>
    </div>

    <!-- Exceptional Info -->
    <div id="exceptional-info" class="exceptional-info">
      <h2>{t('pages.home.exceptional.title')}</h2>
      <p>{t('pages.home.exceptional.description')}</p>
    </div>

    <!-- Our Values Link -->
    <div class="our-values-link">
      <a href={`/${locale}/our-values`}>
        <Fragment set:html={getUiSvgIcon('accessibility')} />
        <p>{tNumbers('our-values')}</p>
      </a>
    </div>

    <!-- YouTube embed -->
    <div style="text-align: center;">
      <h2>Teaser 2027</h2>
      <div class="youtube-container">
        <iframe
          src="https://www.youtube-nocookie.com/embed/t_1-8ajyO6c"
          title="Teaser 2027"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          referrerpolicy="strict-origin-when-cross-origin"
          allowfullscreen
          frameborder="0"
        ></iframe>
      </div>
    </div>
  </div>


  <!-- Map -->
  <InteractiveMap
    client:only="react"
    title={tMap('title')}
    description={tMap('description')}
    locale={locale}
  />

  <!-- Tickets -->
  <!--<div class="section full-width">-->
  <!--  <h2>{tTickets('name')}</h2>-->
  <!--  <div class="tickets-grid">-->
  <!--    <div class="ticket-wrapper">-->
  <!--      <div class="ticket active">-->
  <!--        <div class="ticket-header">✨ {tTickets('2days-2nd')} ✨</div>-->
  <!--        <div class="ticket-price">110 € <span class="ht">HT</span></div>-->
  <!--        <div class="ticket-info">-->
  <!--          <p>2400 places</p>-->
  <!--          <p>11/09/2027 23h55</p>-->
  <!--        </div>-->
  <!--      </div>-->
  <!--    </div>-->
  <!--    <div class="ticket-wrapper">-->
  <!--      <div class="ticket active">-->
  <!--        <div class="ticket-header">✨ {tTickets('1day')} ✨</div>-->
  <!--        <div class="ticket-price">70 € <span class="ht">HT</span></div>-->
  <!--        <div class="ticket-info">-->
  <!--          <p>700 places</p>-->
  <!--          <p>11/09/2027 23h55</p>-->
  <!--        </div>-->
  <!--      </div>-->
  <!--    </div>-->
  <!--  </div>-->
  <!--</div>-->



  <!-- Photos -->
  <div class="section full-width">
    <div class="photos-grid">
      <div class="photo-item high" style="grid-column: 1; grid-row: span 2;">
        <img src={photos[0].src} alt="" />
      </div>
      <div class="photo-item low" style="grid-column: span 2;">
        <img src={photos[1].src} alt="" />
      </div>
      <div class="photo-item low" style="grid-column: span 2;">
        <img src={photos[2].src} alt="" style="object-position: top;" />
      </div>
      <div class="photo-tile" style="grid-column: span 2;">
        <p>{tPhotos('p1')}</p>
        <p style="margin-top: 0;">{tPhotos('p2')}</p>
        <a href="https://photos.app.goo.gl/H1EqkeCNkjjYMxCCA" target="_blank" class="btn btn-primary">
          {tPhotos('button')}
        </a>
      </div>
      <div class="photo-item high" style="grid-column: span 1; grid-row: span 2;">
        <img src={photos[3].src} alt="" />
      </div>
      <div class="photo-item square" style="grid-column: span 1;">
        <img src={photos[4].src} alt="" />
      </div>
      <div class="photo-item low" style="grid-column: span 2;">
        <img src={photos[7].src} alt="" />
      </div>
      <div class="photo-item square" style="grid-column: span 1;">
        <img src={photos[5].src} alt="" />
      </div>
      <div class="photo-item square no-mobile" style="grid-column: span 1;">
        <img src={photos[6].src} alt="" />
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .numbers-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 8px;
    justify-items: center;
    margin: 20px 0;
  }
  @media (max-width: 900px) {
    .numbers-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 600px) {
    .numbers-grid { grid-template-columns: repeat(2, 1fr); }
  }
  .number-item {
    text-align: center;
    min-width: 100px;
  }
  .number-item h2 {
    margin: 10px 0;
  }

  .youtube-container {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
  }
  .youtube-container iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  :global(.interactive-map-section) {
    position: relative;
    width: 100%;
    height: 500px;
  }
  :global(.interactive-map-section .leaflet-container) {
    width: 100%;
    height: 100%;
  }
  :global(.map-info-overlay) {
    position: absolute;
    bottom: 20px;
    left: 20px;
    background-color: var(--primary);
    color: white;
    padding: 20px;
    max-width: 40vw;
    z-index: 1000;
  }
  @media (max-width: 600px) {
    :global(.interactive-map-section) {
      height: 450px;
    }
    :global(.map-info-overlay) {
      position: relative;
      bottom: auto;
      left: auto;
      max-width: 100%;
    }
  }

  .tickets-grid {
    display: flex;
    justify-content: center;
    gap: 24px;
    flex-wrap: wrap;
    margin: 20px 0;
  }

  .exceptional-info {
    background-color: var(--primary);
    color: white;
    border-radius: 12px;
    padding: 32px;
    margin: 40px 0;
    text-align: center;
    scroll-margin-top: 80px;
    border: 3px solid var(--secondary);
  }
  .exceptional-info h2 {
    margin-top: 0;
    color: white;
  }
  .exceptional-info p {
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.9);
  }

  .photos-grid {
    display: grid;
    gap: 8px;
    grid-template-columns: repeat(5, 1fr);
    grid-template-rows: repeat(3, 30vh);
    grid-auto-flow: dense;
  }
  @media (max-width: 600px) {
    .photos-grid {
      grid-template-columns: repeat(3, 1fr);
      grid-template-rows: repeat(5, 17vh);
    }
    .no-mobile { display: none; }
  }
  .photo-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .photo-item.square img { aspect-ratio: 1 / 1; }
  .photo-item.low img { aspect-ratio: 16 / 9; }
  .photo-tile {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .btn {
    display: inline-block;
    padding: 8px 16px;
    border-radius: 4px;
    text-decoration: none;
    font-size: 0.95rem;
    cursor: pointer;
    color: white;
  }
  .btn-secondary {
    background-color: var(--secondary);
  }
  .btn-secondary:hover { opacity: 0.9; }
  .btn-primary {
    background-color: var(--primary);
    border: 1px solid rgba(255, 255, 255, 0.3);
  }
  .btn-primary:hover { background-color: #1a2d42; }
</style>
