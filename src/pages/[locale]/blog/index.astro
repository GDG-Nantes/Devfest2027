---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getTranslation, getLocaleFromParams } from '@/i18n/i18n';
import i18nConfig from '@/i18n/i18nConfig';
import { getAllBlogPosts } from '@/services/blog';
import '@/styles/blog.scss';

export function getStaticPaths() {
  return i18nConfig.locales.map((locale) => ({ params: { locale } }));
}

const locale = getLocaleFromParams(Astro.params);
const t = await getTranslation(locale);
const posts = getAllBlogPosts();

const dateLocale = locale === 'fr' ? 'fr-FR' : 'en-US';

function formatDate(dateString: string): string {
  try {
    const date = new Date(dateString);
    return date.toLocaleDateString(dateLocale, {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    });
  } catch {
    return dateString;
  }
}

function stripMarkdown(text: string): string {
  return text
    .replace(/<.+?>/g, '')
    .replace(/\*\*(.*?)\*\*/g, '$1')
    .replace(/\*(.*?)\*/g, '$1')
    .replace(/__(.*?)__/g, '$1')
    .replace(/_(.*?)_/g, '$1')
    .replace(/`(.*?)`/g, '$1')
    .replace(/~~(.*?)~~/g, '$1')
    .replace(/\[(.*?)\]\(.*?\)/g, '$1')
    .replace(/#{1,6}\s+/g, '')
    .replace(/>\s+/g, '')
    .replace(/[-*+]\s+/g, '')
    .replace(/\d+\.\s+/g, '')
    .replace(/\n/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();
}
---

<BaseLayout locale={locale} title={`${t('pages.blog.name')} - Devfest Nantes`}>
  <div class="blog-page section">
    <h1>{t('pages.blog.name')}</h1>
    <div class="blog-list">
      {posts.map((post, index) => {
        const isEven = index % 2 === 0;
        return (
          <a href={`/${locale}/blog/${post.slug}`} class="blog-post-link">
            <div class:list={['blog-post', isEven ? 'image-left' : 'image-right', !post.image && 'no-image']}>
              {post.image && (
                <div class="blog-image">
                  <img src={post.image} alt={post.title} loading="lazy" />
                </div>
              )}
              <div class="blog-content">
                <h2 class="no-leaf">{post.title}</h2>
                <p class="blog-excerpt">{stripMarkdown(post.content)}</p>
                <div class="blog-meta">
                  <span class="blog-date">{formatDate(post.date)}</span>
                </div>
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</BaseLayout>
