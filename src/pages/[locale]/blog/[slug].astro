---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getLocaleFromParams } from '@/i18n/i18n';
import i18nConfig from '@/i18n/i18nConfig';
import { getAllBlogPosts, getBlogPostBySlug } from '@/services/blog';
import { Markdown } from '@/components/react/Markdown';
import '@/styles/blog.scss';

export function getStaticPaths() {
  const posts = getAllBlogPosts();
  return i18nConfig.locales.flatMap((locale) =>
    posts.map((post) => ({
      params: { locale, slug: post.slug },
    }))
  );
}

const locale = getLocaleFromParams(Astro.params);
const { slug } = Astro.params;
const post = getBlogPostBySlug(slug!, locale);
if (!post) {
  return Astro.redirect(`/${locale}/blog`);
}
---

<BaseLayout locale={locale} title={`${post.title} - Devfest Nantes`}>
  <div class="blog-detail">
    {post.image && (
      <div class="blog-hero">
        <img src={post.image} alt={post.title} class="blog-hero-image" />
        <div class="blog-hero-overlay" />
        {!post.hideTitle && (
          <div class="blog-hero-content">
            <h1 class="no-leaf">{post.title}</h1>
          </div>
        )}
      </div>
    )}
    {!post.image && !post.hideTitle && (
      <div class="section">
        <h1 class="no-leaf">{post.title}</h1>
      </div>
    )}
    <div class="blog-body section">
      <Markdown client:load content={post.content} />
    </div>
  </div>
</BaseLayout>
