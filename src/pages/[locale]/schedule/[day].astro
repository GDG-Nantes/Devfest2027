---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getTranslation, getLocaleFromParams } from '@/i18n/i18n';
import i18nConfig from '@/i18n/i18nConfig';
import { getAllSessions } from '@/services/sessions';
import { getSpeakerBySlug } from '@/services/speakers';
import Slots from '../../../../data/slots.json';
import type { Slot } from '@/types/slots';
import type { RoomName } from '@/types/schedule';
import '@/styles/schedule.scss';

export function getStaticPaths() {
  return i18nConfig.locales.flatMap((locale) =>
    [{ params: { locale, day: '1' } }, { params: { locale, day: '2' } }]
  );
}

const locale = getLocaleFromParams(Astro.params);
const t = await getTranslation(locale, 'pages.schedule');

const { day: dayParam } = Astro.params;
const day = parseInt(dayParam || '1') as 1 | 2;

const typedSlots = Slots.slots as Slot[];
const allHoursSlots = typedSlots
  .filter((s) => s.key.startsWith('day-' + day))
  .filter((s) => s.type !== 'codelab');

const fixedSlots = allHoursSlots.filter((s) =>
  ['opening', 'lunch', 'break', 'keynote', 'party'].includes(s.type)
);

const allSessions = getAllSessions();
const sessions = allSessions.filter((s) => s.slot.key.startsWith('day-' + day));

const rooms: RoomName[] = [
  'Jules Verne', 'Titan', 'Belem', 'Tour Bretagne',
  'Les Machines', 'Hangar', "L'Atelier", 'Unconf',
];

// Group sessions and fixed slots by hour
const hoursStart = allHoursSlots.map((slot) => slot.start);
const uniqueHours = hoursStart.filter((start, i) => hoursStart.indexOf(start) === i);
const hoursSlots = uniqueHours.map(
  (start) => allHoursSlots.find((slot) => slot.start === start) as Slot
);

const sessionsByHours: Record<string, typeof sessions> = {};
const fixedSlotsByHours: Record<string, Slot[]> = {};
hoursSlots.forEach((hourSlot) => {
  sessionsByHours[hourSlot.start] = sessions
    .filter((s) => s.slot.start === hourSlot.start)
    .sort((s1, s2) => rooms.indexOf(s1.room) - rooms.indexOf(s2.room));
  fixedSlotsByHours[hourSlot.start] = fixedSlots.filter(
    (s) => s.start === hourSlot.start
  );
});

function columnFromRoom(room: RoomName): string {
  return rooms.indexOf(room) + 2 + ' / ' + (rooms.indexOf(room) + 2);
}

function slotToRow(slot: Slot): string {
  const firstRow = 1;
  const rowStart = slot.display.row + firstRow;
  const spanRow = slot.display.size;
  return `${rowStart} / span ${spanRow}`;
}

function getFixedSlotColumn(slot: Slot): string {
  if (slot.type.startsWith('keynote')) return '2 / 2';
  if (slot.display.notForCodelab) return '2 / span 4';
  return '2 / -1';
}

function getFlagSrc(lang: string): string {
  return lang.toLowerCase().startsWith('f') ? '/images/flags/fr.svg' : '/images/flags/en.svg';
}
---

<BaseLayout locale={locale} title={`${t('name')} - Devfest Nantes`}>
  <div class="schedule-page">
    <div class="header-days">
      <a href={`/${locale}/schedule/1`} class:list={['button-schedule', 'day1', day === 1 && 'current']}>
        {t('day1-number')}
      </a>
      <a href={`/${locale}/schedule/2`} class:list={['button-schedule', 'day2', day === 2 && 'current']}>
        {t('day2-number')}
      </a>
    </div>

    <!-- Desktop schedule -->
    <div class="header-rooms sticky"></div>
    <div class="schedule-large">
      {rooms.map((room) => (
        <div
          class="slot room sticky"
          style={`grid-column: ${columnFromRoom(room)}; grid-row: 1 / 1;`}
        >
          <h3>{room}</h3>
        </div>
      ))}
      {hoursSlots.map((hourSlot) => (
        <>
          <div
            class="slot"
            style={`grid-column: 1 / 1; grid-row: ${slotToRow(hourSlot)};`}
          >
            <h3>{hourSlot.start}</h3>
          </div>
          {fixedSlotsByHours[hourSlot.start].map((slot) => (
            <div
              class:list={['slot', 'fixed', slot.type]}
              style={`grid-column: ${getFixedSlotColumn(slot)}; grid-row: ${slotToRow(slot)}; z-index: 0;`}
            >
              <h3>{t(slot.type)}</h3>
            </div>
          ))}
          {sessionsByHours[hourSlot.start].map((session) => {
            const speakersFull = session.speakers.map((key) => getSpeakerBySlug(key)).filter(Boolean);
            return (
              <div
                class:list={['slot', 'session-info', session.cancelled && 'cancelled']}
                style={`grid-column: ${columnFromRoom(session.room)}; grid-row: ${slotToRow(session.slot)}; z-index: 1;`}
              >
                <a href={`/${locale}/sessions/${session.key}`}>
                  <span class="session-title">{session.title}</span>
                </a>
                <span class="sr-only">Salle {session.room}</span>
                <div class="session-info-bottom">
                  <div style="display: flex; align-items: center; gap: 6px;">
                    {session.tags?.map((tag) => (
                      <span class="schedule-tag">{tag}</span>
                    ))}
                    <img src={getFlagSrc(session.language)} alt={session.language} width="16" height="12" style="vertical-align: middle;" />
                  </div>
                  <div class="speakers">
                    {speakersFull.map((speaker: any) => (
                      <a href={`/${locale}/speakers/${speaker.key}`} class="speaker">
                        {speaker.photoUrl && (
                          <img
                            src={`/images/speakers/${speaker.photoUrl}`}
                            alt={speaker.name}
                            width="24"
                            height="24"
                            style="border-radius: 50%; object-fit: cover; margin-right: 4px;"
                            loading="lazy"
                          />
                        )}
                        {speakersFull.length === 1 && speaker.name}
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            );
          })}
        </>
      ))}
    </div>

    <!-- Mobile schedule -->
    <div class="mobile-schedule">
      {uniqueHours.map((hour) => (
        <>
          <div class="hour">
            <h3>{hour}</h3>
          </div>
          {sessionsByHours[hour].map((session) => {
            const speakersFull = session.speakers.map((key) => getSpeakerBySlug(key)).filter(Boolean);
            return (
              <div class:list={['slot', 'session-info', session.cancelled && 'cancelled']}>
                <a href={`/${locale}/sessions/${session.key}`}>
                  <span class="session-title">{session.title}</span>
                </a>
                <div style="display: flex; align-items: center; gap: 8px; flex-wrap: wrap;">
                  {session.tags?.map((tag) => (
                    <span class="schedule-tag">{tag}</span>
                  ))}
                  <img src={getFlagSrc(session.language)} alt={session.language} width="16" height="12" />
                  <span>{session.room}</span>
                </div>
                <div class="speakers">
                  {speakersFull.map((speaker: any) => (
                    <a href={`/${locale}/speakers/${speaker.key}`} class="speaker">
                      {speaker.photoUrl && (
                        <img
                          src={`/images/speakers/${speaker.photoUrl}`}
                          alt={speaker.name}
                          width="24"
                          height="24"
                          style="border-radius: 50%; object-fit: cover; margin-right: 4px;"
                          loading="lazy"
                        />
                      )}
                      {speaker.name}
                    </a>
                  ))}
                </div>
              </div>
            );
          })}
          {fixedSlotsByHours[hour].map((slot) => (
            <div class:list={['slot', 'fixed', slot.type]}>
              <h3>{t(slot.type)}</h3>
            </div>
          ))}
        </>
      ))}
    </div>
  </div>
</BaseLayout>
